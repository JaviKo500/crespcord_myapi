<?php

/**
 * @file
 * Routing for the myapi module.
 */

// The i18n helpers (myapi_get_lang() / myapi_t()) are used by the shared
// response and request helpers, so load them globally on every request.
module_load_include('inc', 'myapi', 'includes/myapi.i18n');

/**
 * Implements hook_menu().
 */
function myapi_menu() {
  $items = [];

  $items['api/v1/ping'] = [
    'page callback'    => 'myapi_ping_dispatch',
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/ping.resource.inc',
  ];

  $items['api/v1/auth/login'] = [
    'page callback'    => 'myapi_auth_dispatch',
    'access callback'  => TRUE,
