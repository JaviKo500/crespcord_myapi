  $items['api/v1/ping'] = [
    'page callback'    => 'myapi_ping_dispatch',
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/ping.resource.inc',
  ];

  $items['api/v1/auth/login'] = [
    'page callback'    => 'myapi_auth_dispatch',
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/auth.resource.inc',
  ];

  $items['api/v1/auth/refresh'] = [
    'page callback'    => 'myapi_auth_refresh_dispatch',
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/auth.resource.inc',
  ];

  $items['api/v1/auth/logout'] = [
    'page callback'    => 'myapi_auth_logout_dispatch',
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/auth.resource.inc',
  ];

  $items['api/v1/auth/password/forgot'] = [
    'page callback'    => 'myapi_auth_password_forgot_dispatch',
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/auth.resource.inc',
  ];

  $items['api/v1/auth/password/reset'] = [
    'page callback'    => 'myapi_auth_password_reset_dispatch',
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/auth.resource.inc',
  ];

  $items['password/reset'] = [
    'page callback'    => 'myapi_auth_password_reset_page',
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/auth.resource.inc',
  ];

  $items['api/v1/units'] = [
    'page callback'    => 'myapi_unit_dispatch',
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/unit.resource.inc',
  ];

  $items['api/v1/units/%/receipts'] = [
    'page callback'    => 'myapi_receipt_dispatch',
    'page arguments'   => [3],
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/receipt.resource.inc',
  ];

  $items['api/v1/units/%/extra-fees'] = [
    'page callback'    => 'myapi_extra_fee_dispatch',
    'page arguments'   => [3],
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/extra_fee.resource.inc',
  ];

  $items['api/v1/units/%/payments'] = [
    'page callback'    => 'myapi_payment_dispatch',
    'page arguments'   => [3],
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/payment.resource.inc',
  ];

  $items['api/v1/payments'] = [
    'page callback'    => 'myapi_payment_create_dispatch',
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/payment.resource.inc',
  ];

  $items['api/v1/payments/%/cancel'] = [
    'page callback'    => 'myapi_payment_cancel_dispatch',
    'page arguments'   => [3],
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/payment.resource.inc',
  ];

  $items['api/v1/payments/%'] = [
    'page callback'    => 'myapi_payment_detail_dispatch',
    'page arguments'   => [3],
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/payment.resource.inc',
  ];

  $items['api/v1/condominiums/%/expenses'] = [
    'page callback'    => 'myapi_expense_dispatch',
    'page arguments'   => [3],
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/expense.resource.inc',
  ];

  $items['api/v1/condominiums/%/summary'] = [
    'page callback'    => 'myapi_condominium_dispatch',
    'page arguments'   => [3],
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/condominium.resource.inc',
  ];

  $items['api/v1/condominiums/%/areas'] = [
    'page callback'    => 'myapi_area_dispatch',
    'page arguments'   => [3],
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/area.resource.inc',
  ];

  $items['api/v1/banks'] = [
    'page callback'    => 'myapi_bank_dispatch',
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/bank.resource.inc',
  ];

  $items['api/v1/payment-methods'] = [
    'page callback'    => 'myapi_payment_method_dispatch',
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/payment_method.resource.inc',
  ];

  $items['api/v1/notifications'] = [
    'page callback'    => 'myapi_notification_dispatch',
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/notification.resource.inc',
  ];

  // The exact 'read-all' path must be registered alongside the '%' wildcard;
  // Drupal's router prefers the literal path, so both can coexist.
  $items['api/v1/notifications/read-all'] = [
    'page callback'    => 'myapi_notification_read_all_dispatch',
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/notification.resource.inc',
  ];

  $items['api/v1/notifications/%'] = [
    'page callback'    => 'myapi_notification_read_dispatch',
    'page arguments'   => [3],
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/notification.resource.inc',
  ];

  $items['api/v1/bulletins'] = [
    'page callback'    => 'myapi_bulletin_dispatch',
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/bulletin.resource.inc',
  ];

  return $items;
}

/**
 * Implements hook_mail().
 */
function myapi_mail($key, &$message, $params) {
  if ($key == 'password_reset') {
    module_load_include('inc', 'myapi', 'includes/myapi.mail');
    myapi_mail_format_password_reset($message, $params);
  }
}

/**
 * Implements hook_node_presave().
 *
 * Glue only: ignores everything that is not a 'pagos' node and delegates the
 * payment verification workflow to includes/myapi.payment_workflow.inc. The
 * type guard on the first line keeps every other node save untouched and avoids
 * recursion when the workflow re-saves the 'vivienda' and 'condominio' nodes.
 */
function myapi_node_presave($node) {
  if ($node->type !== 'pagos') {
    return;
  }
  module_load_include('inc', 'myapi', 'includes/myapi.payment_workflow');
  if (myapi_payment_is_verification_transition($node)) {
    myapi_payment_apply_verification($node);
  }
}

/**
 * Implements hook_node_insert().
 *
 * Glue only. Two independent branches:
 * - 'pagos' created directly with field_estado_pago = "Completado": delegates
 *   to myapi_payment_notify_approved() in includes/myapi.payment_workflow.inc
 *   (the verification-transition case is already covered by
 *   myapi_node_presave() above; this branch only covers direct creation,
 *   where $node->nid did not exist yet in presave).
 * - Published 'boletin' node: delegates the notification fan-out + push
 *   enqueue to includes/myapi.notification.inc. A bulletin saved as a draft
 *   (status 0) does not notify anyone; editing or publishing it later does
 *   not fire either (only insert of a published node).
 */
function myapi_node_insert($node) {
  if ($node->type === 'pagos') {
    module_load_include('inc', 'myapi', 'includes/myapi.payment_workflow');
    if (myapi_payment_field_value($node, 'field_estado_pago') === MYAPI_PAYMENT_STATUS_COMPLETED) {
      myapi_payment_notify_approved($node);
    }
    return;
  }
  if ($node->type !== 'boletin' || $node->status != 1) {
    return;
  }
  module_load_include('inc', 'myapi', 'includes/myapi.notification');
  myapi_notification_create_from_boletin($node);
}

/**
 * Implements hook_node_update().
 *
 * Glue only. Two independent branches:
 * - 'pagos': delegates to myapi_payment_is_rule_completion() /
 *   myapi_payment_notify_approved() in includes/myapi.payment_workflow.inc.
 *   Covers the "Nuevo" -> "Completado" transition produced by the legacy Rule
 *   'rules_actualizar_saldo_pago' when it auto-saves a 'pagos' node created
 *   directly in "Nuevo" (the Rule already did the balance work; this hook only
 *   notifies). Also delegates to myapi_payment_is_cancellation_transition() /
 *   myapi_payment_notify_cancelled() for a back-office "* -> Anulado" update
 *   (the opt-out save from PUT /api/v1/payments/%/cancel never matches it).
 * - 'recibo' / 'alicuota_extra': delegates to myapi_fee_is_sent_transition() /
 *   myapi_fee_notify_issued() in includes/myapi.fee_notification.inc, notifying
 *   the unit occupants when the fee transitions to "Enviado" on edit.
 */
function myapi_node_update($node) {
  if ($node->type === 'pagos') {
    module_load_include('inc', 'myapi', 'includes/myapi.payment_workflow');
    if (myapi_payment_is_rule_completion($node)) {
      myapi_payment_notify_approved($node);
    }
    elseif (myapi_payment_is_cancellation_transition($node)) {
      myapi_payment_notify_cancelled($node);
    }
    return;
  }
  if ($node->type === 'recibo' || $node->type === 'alicuota_extra') {
    module_load_include('inc', 'myapi', 'includes/myapi.fee_notification');
    if (myapi_fee_is_sent_transition($node)) {
      myapi_fee_notify_issued($node);
    }
  }
}

/**
 * Implements hook_cron_queue_info().
 *
 * Registers the worker that drains the OneSignal push queue. This hook is
 * invoked by drupal_cron_run() right before it processes the queues in the same
 * request, so loading the include here guarantees the worker function is
 * defined when the queue is drained. A failing item is retried on the next cron
 * (standard Queue API behaviour).
 */
function myapi_cron_queue_info() {
  // Load the include so the worker callback is defined when drupal_cron_run()
  // drains the queue later in this same request. The queue name comes from the
  // constant defined at the top of this file, so it never depends on the load
  // above succeeding.
  module_load_include('inc', 'myapi', 'includes/myapi.onesignal');

  $queues = [];
  $queues[MYAPI_ONESIGNAL_QUEUE] = [
    'worker callback' => 'myapi_onesignal_queue_worker',
    'time'            => 60,
  ];
  return $queues;
}
