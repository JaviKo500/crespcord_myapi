<?php

/**
 * @file
 * Routing for the myapi module.
 */

/**
 * Implements hook_menu().
 */
function myapi_menu() {
  $items = [];

  $items['api/v1/ping'] = [
    'page callback'    => 'myapi_ping_dispatch',
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/ping.resource.inc',
  ];

  $items['api/v1/auth/login'] = [
    'page callback'    => 'myapi_auth_dispatch',
    'access callback'  => TRUE,
    'type'             => MENU_CALLBACK,
    'file'             => 'resources/auth.resource.inc',
  ];

  return $items;
}
