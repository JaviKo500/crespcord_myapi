<?php

/**
 * @file
 * Routing for the myapi module.
 */

// The i18n helpers (myapi_get_lang() / myapi_t()) are used by the shared
// response and request helpers, so load them globally on every request.
module_load_include('inc', 'myapi', 'includes/myapi.i18n');

// OneSignal push queue name. Defined here in the always-loaded .module (not only
// in includes/myapi.notification.inc) because hook_cron_queue_info() references
// it to register the worker: during cron that hook can run before its include
// is loaded, and an undefined constant would register the worker under the wrong
// queue name, so items enqueued as 'myapi_onesignal_push' would never drain.
if (!defined('MYAPI_ONESIGNAL_QUEUE')) {
  define('MYAPI_ONESIGNAL_QUEUE', 'myapi_onesignal_push');
}

