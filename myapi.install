      ],
    ],
    'widget'      => ['type' => 'entityreference_autocomplete'],
  ]);
  _myapi_reservations_ensure_instance('field_date', 'reservation', [
    'field_name'  => 'field_date',
    'entity_type' => 'node',
    'bundle'      => 'reservation',
    'label'       => 'Fecha',
    'required'    => 1,
    'widget'      => [
      'type'     => 'date_select',
      'settings' => [
        'input_format'   => 'Y-m-d',
        'year_range'     => '-1:+3',
        'increment'      => 1,
        'label_position' => 'above',
        'text_parts'     => [],
      ],
    ],
  ]);
  _myapi_reservations_ensure_instance('field_start_time', 'reservation', [
    'field_name'  => 'field_start_time',
    'entity_type' => 'node',
    'bundle'      => 'reservation',
    'label'       => 'Hora de inicio',
    'required'    => 1,
    'widget'      => ['type' => 'text_textfield'],
  ]);
  _myapi_reservations_ensure_instance('field_end_time', 'reservation', [
    'field_name'  => 'field_end_time',
    'entity_type' => 'node',
    'bundle'      => 'reservation',
    'label'       => 'Hora de fin',
    'required'    => 1,
    'widget'      => ['type' => 'text_textfield'],
  ]);
  _myapi_reservations_ensure_instance('field_reservation_status', 'reservation', [
    'field_name'    => 'field_reservation_status',
    'entity_type'   => 'node',
    'bundle'        => 'reservation',
    'label'         => 'Estado de la reserva',
    'required'      => 1,
    'default_value' => [['value' => 'confirmed']],
    'widget'        => ['type' => 'options_select'],
  ]);
  _myapi_reservations_ensure_instance('field_cancelled_by', 'reservation', [
    'field_name'  => 'field_cancelled_by',
    'entity_type' => 'node',
    'bundle'      => 'reservation',
    'label'       => 'Cancelada por',
    'required'    => 0,
    'widget'      => ['type' => 'options_select'],
  ]);
}

/**
 * Creates the my_api_tokens table on sites where the module is already enabled.
 */
function myapi_update_7001() {
  if (!db_table_exists('my_api_tokens')) {
    $schema = drupal_get_schema_unprocessed('myapi', 'my_api_tokens');
    db_create_table('my_api_tokens', $schema);
  }
}

/**
 * Creates the myapi_password_reset_tokens table on sites where the module is
 * already enabled.
 */
function myapi_update_7002() {
  if (!db_table_exists('myapi_password_reset_tokens')) {
    $schema = drupal_get_schema_unprocessed('myapi', 'myapi_password_reset_tokens');
    db_create_table('myapi_password_reset_tokens', $schema);
  }
}

/**
 * Registers the HTML mail system for the password reset email on sites where
 * the module is already enabled.
 */
function myapi_update_7003() {
  myapi_mail_system_register();
}

/**
 * Creates the myapi_notifications table on sites where the module is already
 * enabled.
 */
function myapi_update_7004() {
  if (!db_table_exists('myapi_notifications')) {
    $schema = drupal_get_schema_unprocessed('myapi', 'myapi_notifications');
    db_create_table('myapi_notifications', $schema);
  }
}

/**
 * Adds condominium_id and unit_id to myapi_notifications on sites where the
 * table already exists.
 */
function myapi_update_7005() {
  if (!db_field_exists('myapi_notifications', 'condominium_id')) {
    db_add_field('myapi_notifications', 'condominium_id', [
      'description' => 'Logical FK to the condominium node (nid). NULL for notifications with no single condominium context (e.g. boletin fan-out).',
      'type'        => 'int',
      'unsigned'    => TRUE,
      'not null'    => FALSE,
    ]);
  }
  if (!db_field_exists('myapi_notifications', 'unit_id')) {
    db_add_field('myapi_notifications', 'unit_id', [
      'description' => 'Logical FK to the unit (vivienda) node (nid). NULL for notifications with no single unit context (e.g. boletin fan-out).',
      'type'        => 'int',
      'unsigned'    => TRUE,
      'not null'    => FALSE,
    ]);
  }
}
